{
  "compilerOptions": {
    "module": "es6",
    "target": "ES2017",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "noImplicitThis": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
